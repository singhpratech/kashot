<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Kashot"
           Manufacturer="singhpratech"
           Version="1.0.0"
           UpgradeCode="94810024-659B-4781-A523-F60C707AF83A"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Kashot — Windows tray screenshot tool with annotation editor"
                        Manufacturer="singhpratech" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Kashot is already installed." />

    <Icon Id="KashotIcon.ico" SourceFile="!(bindpath.app)Kashot.ico" />
    <Property Id="ARPPRODUCTICON" Value="KashotIcon.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/singhpratech/kashot" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/singhpratech/kashot" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPNOMODIFY" Value="1" />

    <Feature Id="Main" Title="Kashot" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Kashot" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Kashot" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Component Id="KashotExe" Bitness="always64">
        <File Id="KashotExeFile"
              Source="!(bindpath.app)Kashot.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="6A29F2E1-4E8B-4B5A-9C2E-1A8B3F9D2C4E">
        <Shortcut Id="KashotStartMenuShortcut"
                  Name="Kashot"
                  Description="Kashot screenshot tool"
                  Target="[INSTALLFOLDER]Kashot.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="KashotIcon.ico" />
        <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\singhpratech\Kashot"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="B85C9F7A-2D3E-4F1A-8B6C-7E9A0D5C3B12">
        <Shortcut Id="KashotDesktopShortcut"
                  Name="Kashot"
                  Description="Kashot screenshot tool"
                  Target="[INSTALLFOLDER]Kashot.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="KashotIcon.ico" />
        <RegistryValue Root="HKCU"
                       Key="Software\singhpratech\Kashot"
                       Name="desktop_shortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Package>

</Wix>
